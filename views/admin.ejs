<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Admin Panel</title>
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@700;800&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    body {
      font-family: 'DM Sans', sans-serif;
      background: #0d0f14;
      color: #e8eaf2;
      min-height: 100vh;
      padding: 2.5rem 1.5rem;
      background-image:
        radial-gradient(ellipse 70% 40% at 0% 0%, rgba(248,113,113,0.07) 0%, transparent 60%),
        radial-gradient(ellipse 50% 40% at 100% 100%, rgba(91,106,249,0.07) 0%, transparent 60%);
    }

    .container {
      max-width: 720px;
      margin: 0 auto;
    }

    /* ── Header ── */
    .header {
      margin-bottom: 2rem;
    }

    .header .badge {
      display: inline-block;
      font-size: 0.68rem;
      font-weight: 500;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: #f87171;
      background: rgba(248,113,113,0.1);
      border: 1px solid rgba(248,113,113,0.25);
      border-radius: 20px;
      padding: 0.3rem 0.9rem;
      margin-bottom: 0.6rem;
    }

    h1 {
      font-family: 'Syne', sans-serif;
      font-size: clamp(1.8rem, 4vw, 2.4rem);
      font-weight: 800;
      letter-spacing: -0.03em;
      background: linear-gradient(135deg, #fff 30%, #f87171);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      margin-bottom: 1.5rem;
    }

    /* ── Stat Cards ── */
    .stats {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 0.75rem;
      margin-bottom: 2rem;
    }

    .stat-card {
      background: #13161e;
      border: 1px solid #252a38;
      border-radius: 14px;
      padding: 1.25rem 1.5rem;
      position: relative;
      overflow: hidden;
    }

    .stat-card::before {
      content: '';
      position: absolute;
      top: -30px; right: -30px;
      width: 100px; height: 100px;
      border-radius: 50%;
      pointer-events: none;
    }

    .stat-card.users::before  { background: radial-gradient(circle, rgba(91,106,249,0.15) 0%, transparent 70%); }
    .stat-card.scores::before { background: radial-gradient(circle, rgba(52,211,153,0.15) 0%, transparent 70%); }

    .stat-label {
      font-size: 0.7rem;
      font-weight: 500;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: #6b7280;
      margin-bottom: 0.4rem;
    }

    .stat-num {
      font-family: 'Syne', sans-serif;
      font-size: 2rem;
      font-weight: 800;
      letter-spacing: -0.03em;
    }

    .stat-card.users  .stat-num { color: #5b6af9; }
    .stat-card.scores .stat-num { color: #34d399; }

    /* ── Section ── */
    hr { display: none; }

    .section {
      margin-bottom: 2rem;
    }

    .section-title {
      font-family: 'Syne', sans-serif;
      font-size: 0.7rem;
      font-weight: 700;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: #5b6af9;
      margin-bottom: 0.75rem;
    }

    /* ── User Row ── */
    .user-row {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      background: #13161e;
      border: 1px solid #252a38;
      border-radius: 10px;
      padding: 0.75rem 1rem;
      margin-bottom: 0.5rem;
      font-size: 0.9rem;
      transition: border-color 0.2s;
    }

    .user-row:hover { border-color: rgba(91,106,249,0.35); }

    .avatar {
      width: 32px;
      height: 32px;
      border-radius: 50%;
      background: rgba(91,106,249,0.15);
      border: 1px solid rgba(91,106,249,0.25);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 0.75rem;
      font-weight: 600;
      color: #5b6af9;
      flex-shrink: 0;
      text-transform: uppercase;
    }

    .user-email { color: #e8eaf2; }

    /* ── Score Row ── */
    .score-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      background: #13161e;
      border: 1px solid #252a38;
      border-radius: 10px;
      padding: 0.85rem 1rem;
      margin-bottom: 0.5rem;
      font-size: 0.9rem;
      transition: border-color 0.2s;
      gap: 0.5rem;
      flex-wrap: wrap;
    }

    .score-row:hover { border-color: rgba(52,211,153,0.25); }

    .score-info { display: flex; flex-direction: column; gap: 0.2rem; flex: 1; }

    .score-course {
      font-weight: 500;
      color: #e8eaf2;
      font-size: 0.9rem;
    }

    .score-meta {
      font-size: 0.78rem;
      color: #6b7280;
    }

    .score-badge {
      font-family: 'Syne', sans-serif;
      font-size: 1.1rem;
      font-weight: 800;
      color: #34d399;
      min-width: 40px;
      text-align: center;
    }

    .delete-btn {
      all: unset;
      cursor: pointer;
      color: #f87171;
      font-size: 0.75rem;
      font-weight: 600;
      letter-spacing: 0.05em;
      text-transform: uppercase;
      text-decoration: none;
      padding: 0.3rem 0.7rem;
      border: 1px solid rgba(248,113,113,0.3);
      border-radius: 6px;
      transition: background 0.2s;
      flex-shrink: 0;
    }

    .delete-btn:hover { background: rgba(248,113,113,0.1); }

    .nav {
      display: flex;
      gap: 0.6rem;
      margin-bottom: 2rem;
      flex-wrap: wrap;
    }

    .nav a {
      display: inline-flex;
      align-items: center;
      gap: 0.35rem;
      text-decoration: none;
      font-family: 'Syne', sans-serif;
      font-size: 0.8rem;
      font-weight: 700;
      letter-spacing: 0.05em;
      border-radius: 8px;
      padding: 0.45rem 0.9rem;
      transition: background 0.2s, border-color 0.2s, transform 0.1s;
    }

    .nav a:hover  { transform: translateY(-1px); }
    .nav a:active { transform: translateY(0); }

    .nav a[href="/"] {
      color: #34d399;
      border: 1px solid rgba(52,211,153,0.3);
    }
    .nav a[href="/"]:hover { background: rgba(52,211,153,0.08); border-color: #34d399; }

    .nav a[href="/dashboard"] {
      color: #a78bfa;
      border: 1px solid rgba(167,139,250,0.3);
    }
    .nav a[href="/dashboard"]:hover { background: rgba(167,139,250,0.08); border-color: #a78bfa; }

    @media (max-width: 480px) {
      .stats { grid-template-columns: 1fr; }
      body { padding: 1.5rem 1rem; }
    }
  </style>
</head>
<body>
  <div class="container">

    <div class="nav">
      <a href="/">← Home</a>
      <a href="/dashboard">⊞ Dashboard</a>
    </div>

    <div class="header">
      <div class="badge">⚙ Admin Panel</div>
      <h1>Admin Dashboard</h1>
    </div>

    <!-- Stat Cards -->
    <div class="stats">
      <div class="stat-card users">
        <div class="stat-label">Total Users</div>
        <div class="stat-num"><%= users.length %></div>
      </div>
      <div class="stat-card scores">
        <div class="stat-label">Total Scores</div>
        <div class="stat-num"><%= scores.length %></div>
      </div>
    </div>

    <hr>

    <!-- Users Section -->
    <div class="section">
      <div class="section-title">Users</div>
      <% users.forEach(function(user){ %>
        <div class="user-row">
          <div class="avatar"><%= user.email ? user.email[0] : '?' %></div>
          <span class="user-email"><%= user.email %></span>
        </div>
      <% }) %>
    </div>

    <hr>

    <!-- Scores Section -->
    <div class="section">
      <div class="section-title">Scores</div>
      <% scores.forEach(function(score){ %>
        <div class="score-row">
          <div class="score-info">
            <span class="score-course"><%= score.courseName %></span>
            <span class="score-meta">👤 <%= score.userId ? score.userId.email : "Unknown" %></span>
          </div>
          <div class="score-badge"><%= score.score %></div>
          <a class="delete-btn" href="/admin/delete/<%= score._id %>">Delete</a>
        </div>
      <% }) %>
    </div>

  </div>
</body>
</html>
