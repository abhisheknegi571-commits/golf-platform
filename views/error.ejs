

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Error</title>
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@700;800&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    body {
      font-family: 'DM Sans', sans-serif;
      background: #0d0f14;
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 1.5rem;
      background-image:
        radial-gradient(ellipse 70% 50% at 50% 0%, rgba(248,113,113,0.1) 0%, transparent 60%),
        radial-gradient(ellipse 40% 40% at 80% 100%, rgba(91,106,249,0.07) 0%, transparent 60%);
    }

    .card {
      background: #13161e;
      border: 1px solid #2e1f1f;
      border-radius: 18px;
      padding: 2.5rem 2rem;
      width: 100%;
      max-width: 380px;
      position: relative;
      overflow: hidden;
      text-align: center;
    }

    .card::before {
      content: '';
      position: absolute;
      top: -80px;
      left: 50%;
      transform: translateX(-50%);
      width: 240px;
      height: 240px;
      background: radial-gradient(circle, rgba(248,113,113,0.12) 0%, transparent 70%);
      pointer-events: none;
    }

    .icon {
      width: 56px;
      height: 56px;
      background: rgba(248,113,113,0.1);
      border: 1px solid rgba(248,113,113,0.25);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      margin: 0 auto 1.5rem;
      font-size: 1.5rem;
    }

    .label {
      font-size: 0.7rem;
      font-weight: 500;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: #f87171;
      margin-bottom: 0.4rem;
    }

    h2 {
      font-family: 'Syne', sans-serif;
      font-size: 2rem;
      font-weight: 800;
      letter-spacing: -0.03em;
      color: #e8eaf2;
      margin-bottom: 1.25rem;
    }

    .message {
      background: rgba(248,113,113,0.07);
      border: 1px solid rgba(248,113,113,0.2);
      border-radius: 10px;
      color: #fca5a5;
      font-size: 0.9rem;
      line-height: 1.6;
      padding: 0.85rem 1rem;
      margin-bottom: 1.75rem;
    }

    br { display: none; }

    a[href="/dashboard"] {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      background: #5b6af9;
      color: #fff;
      text-decoration: none;
      border-radius: 10px;
      padding: 0.75rem 1.5rem;
      font-family: 'Syne', sans-serif;
      font-size: 0.9rem;
      font-weight: 700;
      letter-spacing: 0.05em;
      transition: background 0.2s, box-shadow 0.2s, transform 0.1s;
      box-shadow: 0 4px 20px rgba(91,106,249,0.28);
    }

    a[href="/dashboard"]::before { content: '←'; }

    a[href="/dashboard"]:hover {
      background: #6b7aff;
      box-shadow: 0 6px 28px rgba(91,106,249,0.42);
      transform: translateY(-1px);
    }

    a[href="/dashboard"]:active {
      transform: translateY(0);
    }
  </style>
</head>
<body>

  <div class="card">
    <div class="icon">⚠</div>
    <p class="label">Something went wrong</p>
    <h2>Error</h2>

    <p class="message" style="color:red">
      <%= message %>
    </p>

    <br>
    <a href="/dashboard">Go Back</a>
  </div>

</body>
</html>
